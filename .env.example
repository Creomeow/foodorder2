# ============================================================
# Food Ordering System — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- Runtime ----
NODE_ENV=development

# ---- Database (PostgreSQL) ----
# Local dev (docker compose exposes 6436:5432)
DATABASE_URL=postgresql://foodorder:foodorder@localhost:6436/foodorder?schema=public

# ---- API server ----
API_PORT=4000
API_URL=http://localhost:4000

# ---- JWT secrets (generate: openssl rand -base64 32) ----
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- CORS (comma separated origins allowed to call the API) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ---- Frontend public URLs (used for QR code generation) ----
CUSTOMER_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ---- Stripe (test mode) ----
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen --forward-to localhost:4000/api/v1/payments/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=sgd

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ---- Seed admin credentials ----
SEED_SUPER_ADMIN_EMAIL=superadmin@foodorder.dev
SEED_SUPER_ADMIN_PASSWORD=Admin123!
SEED_MANAGER_EMAIL=manager@foodorder.dev
SEED_MANAGER_PASSWORD=Manager123!
SEED_STAFF_EMAIL=staff@foodorder.dev
SEED_STAFF_PASSWORD=Staff123!

# ============================================================
# Frontends — set in customer-web/.env (Next.js) and admin-web/.env (Vite)
# ============================================================
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# VITE_API_URL=http://localhost:4000
